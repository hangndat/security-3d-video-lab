{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://security-3d-video-lab/content/narration-track.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "assemblySlug",
    "providerId",
    "fps",
    "captionMapHash",
    "totalDurationSeconds",
    "segments"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "assemblySlug": {
      "type": "string",
      "minLength": 1
    },
    "branchId": {
      "type": "string",
      "minLength": 1
    },
    "providerId": {
      "type": "string",
      "minLength": 1
    },
    "fps": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "captionMapHash": {
      "type": "string",
      "minLength": 1
    },
    "totalDurationSeconds": {
      "type": "number",
      "minimum": 0
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "topic",
          "beatId",
          "analyticKey",
          "startSeconds",
          "endSeconds",
          "targetDurationSeconds",
          "actualDurationSeconds",
          "scriptIntent",
          "providerId",
          "contentHash",
          "audioArtifactPath"
        ],
        "properties": {
          "topic": { "type": "string", "minLength": 1 },
          "beatId": { "type": "string", "minLength": 1 },
          "analyticKey": { "type": "string", "minLength": 1 },
          "startSeconds": { "type": "number", "minimum": 0 },
          "endSeconds": { "type": "number", "exclusiveMinimum": 0 },
          "targetDurationSeconds": { "type": "number", "exclusiveMinimum": 0 },
          "actualDurationSeconds": { "type": "number", "exclusiveMinimum": 0 },
          "scriptIntent": { "type": "string", "minLength": 1 },
          "providerId": { "type": "string", "minLength": 1 },
          "contentHash": { "type": "string", "minLength": 1 },
          "audioArtifactPath": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
