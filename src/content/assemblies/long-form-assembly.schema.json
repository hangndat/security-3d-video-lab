{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://security-3d-video-lab/content/long-form-assembly.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "slug", "sequence", "targetWindowMinutes"],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-long-v[0-9]+$"
    },
    "sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "targetWindowMinutes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "number", "exclusiveMinimum": 0 },
        "max": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "defaultPacingPresetId": {
      "type": "string",
      "minLength": 1
    }
  }
}
