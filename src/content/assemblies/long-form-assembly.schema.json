{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://security-3d-video-lab/content/long-form-assembly.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "slug", "targetWindowMinutes"],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "slug": {
      "type": "string",
      "oneOf": [
        { "pattern": "^[a-z0-9-]+-long-v[0-9]+$" },
        { "pattern": "^[a-z0-9-]+-branched-v[0-9]+$" }
      ]
    },
    "sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "defaultBranchId": {
      "type": "string",
      "minLength": 1
    },
    "branches": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "sequence"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "sequence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            }
          },
          "transitionOverrides": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["fromTopic", "toTopic", "presetId", "rationale"],
              "properties": {
                "fromTopic": {
                  "type": "string",
                  "pattern": "^[a-z0-9-]+$"
                },
                "toTopic": {
                  "type": "string",
                  "pattern": "^[a-z0-9-]+$"
                },
                "presetId": {
                  "type": "string",
                  "minLength": 1
                },
                "rationale": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "targetWindowMinutes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "number", "exclusiveMinimum": 0 },
        "max": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "defaultPacingPresetId": {
      "type": "string",
      "minLength": 1
    }
  },
  "oneOf": [
    {
      "required": ["sequence"],
      "not": { "required": ["branches"] }
    },
    {
      "required": ["branches", "defaultBranchId"],
      "not": { "required": ["sequence"] }
    }
  ]
}
