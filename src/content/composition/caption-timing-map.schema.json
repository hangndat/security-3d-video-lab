{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://security-3d-video-lab/content/caption-timing-map.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "assemblySlug", "fps", "entries"],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "assemblySlug": {
      "type": "string",
      "minLength": 1
    },
    "branchId": {
      "type": "string",
      "minLength": 1
    },
    "fps": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "topic",
          "beatId",
          "startFrame",
          "endFrame",
          "startSeconds",
          "endSeconds",
          "scriptIntent",
          "analyticKey"
        ],
        "properties": {
          "topic": { "type": "string", "minLength": 1 },
          "beatId": { "type": "string", "minLength": 1 },
          "startFrame": { "type": "integer", "minimum": 0 },
          "endFrame": { "type": "integer", "exclusiveMinimum": 0 },
          "startSeconds": { "type": "number", "minimum": 0 },
          "endSeconds": { "type": "number", "exclusiveMinimum": 0 },
          "scriptIntent": { "type": "string", "minLength": 1 },
          "analyticKey": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
