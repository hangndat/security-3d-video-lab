{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://security-3d-video-lab/content/topic-contract.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "topic",
    "slug",
    "hook",
    "cta",
    "durationBudget",
    "storyboardBeats",
    "narrationPlaceholders"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "topic": {
      "type": "string",
      "enum": ["tls", "ssh", "dns"]
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-short-v[0-9]+$"
    },
    "hook": {
      "type": "string",
      "minLength": 1
    },
    "cta": {
      "type": "string",
      "minLength": 1
    },
    "durationBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minSeconds", "targetSeconds", "maxSeconds"],
      "properties": {
        "minSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "targetSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "maxSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "storyboardBeats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "startFrame", "endFrame", "objective"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9-]+$"
          },
          "startFrame": {
            "type": "integer",
            "minimum": 0
          },
          "endFrame": {
            "type": "integer",
            "minimum": 1
          },
          "objective": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "narrationPlaceholders": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["beatId", "analyticKey", "scriptIntent", "timing"],
        "properties": {
          "beatId": {
            "type": "string",
            "minLength": 1
          },
          "analyticKey": {
            "type": "string",
            "pattern": "^[a-z0-9-]+:[a-z0-9-]+$"
          },
          "scriptIntent": {
            "type": "string",
            "minLength": 1
          },
          "timing": {
            "$ref": "#/properties/durationBudget"
          }
        }
      }
    },
    "transitionToNext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["toTopic", "presetId", "rationale"],
      "properties": {
        "toTopic": {
          "type": "string",
          "enum": ["tls", "ssh", "dns"]
        },
        "presetId": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
